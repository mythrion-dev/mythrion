// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String?
  displayName        String?
  onboardingComplete Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  adventures         Adventure[]
  memberships        CampaignMember[]
  sentInvitations    CampaignInvitation[] @relation("SentInvitations")
  googleAccount      GoogleAccount?
  discordAccount     DiscordAccount?
  refreshTokens      RefreshToken[]
  characterSheets    CharacterSheet[]
}

model Adventure {
  id          String            @id @default(cuid())
  name        String
  campaign    String
  synopsis    String?
  maxPlayers  Int               @default(5)
  ownerId     String
  owner       User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  members     CampaignMember[]
  invitations CampaignInvitation[]
  templates   Template[]
  characterSheets CharacterSheet[]

  @@index([ownerId])
}

enum MemberRole {
  GM
  PLAYER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model CampaignMember {
  id         String     @id @default(cuid())
  adventureId  String
  adventure    Adventure @relation(fields: [adventureId], references: [id], onDelete: Cascade)
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       MemberRole
  joinedAt   DateTime   @default(now())
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([adventureId, userId])
  @@index([userId])
}

model CampaignInvitation {
  id           String           @id @default(cuid())
  adventureId     String
  adventure       Adventure      @relation(fields: [adventureId], references: [id], onDelete: Cascade)
  invitedEmail String?
  token        String           @unique
  role         MemberRole
  status       InvitationStatus @default(PENDING)
  expiresAt    DateTime
  acceptedAt   DateTime?
  createdById  String
  createdBy    User             @relation("SentInvitations", fields: [createdById], references: [id])
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([adventureId])
  @@index([token])
}

model GoogleAccount {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String   @unique
  googleId    String   @unique
  email       String
  displayName String?
  avatarUrl   String?
  locale      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DiscordAccount {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String   @unique
  discordId   String   @unique
  username    String
  email       String?  @unique
  avatarUrl   String?
  discriminator String?  // # após o nome de usuário
  locale      String?
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  @@index([userId])
  @@index([token])
}

// ── Character Sheet Templates ──

model Template {
  id                    String                      @id @default(cuid())
  adventureId           String
  adventure             Adventure                   @relation(fields: [adventureId], references: [id], onDelete: Cascade)
  name                  String
  description           String?
  attributes            TemplateAttribute[]
  templateFields        TemplateField[]
  templateSkills        TemplateSkill[]
  skillModifierProfiles SkillModifierProfile[]
  runtimeModifiers      TemplateRuntimeModifier[]
  armorClass            TemplateArmorClass?
  characterSheets       CharacterSheet[]
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  @@index([adventureId])
}

// ── Skill Modifier Profiles ──

model SkillModifierProfile {
  id                String                           @id @default(cuid())
  templateId        String
  template          Template                         @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name              String
  order             Int                              @default(0)
  options           ProfileOption[]
  skillProfileValues CharacterSheetSkillProfileValue[]
  createdAt         DateTime                         @default(now())
  updatedAt         DateTime                         @updatedAt

  @@unique([templateId, name])
  @@index([templateId])
}

model ProfileOption {
  id             String                        @id @default(cuid())
  profileId      String
  profile        SkillModifierProfile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  label          String
  value          Float                         @default(0)
  order          Int                           @default(0)
  selections     CharacterSheetSkillProfileValue[]
  createdAt      DateTime                      @default(now())
  updatedAt      DateTime                      @updatedAt

  @@unique([profileId, label])
  @@index([profileId])
}

// ── Character Sheet Skill Profile Values ──

model CharacterSheetSkillProfileValue {
  id        String              @id @default(cuid())
  sheetId   String
  sheet     CharacterSheet      @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  skillId   String
  skill     TemplateSkill       @relation(fields: [skillId], references: [id], onDelete: Cascade)
  profileId String
  profile   SkillModifierProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  optionId  String?
  option    ProfileOption?      @relation(fields: [optionId], references: [id], onDelete: SetNull)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([sheetId, skillId, profileId])
  @@index([sheetId])
  @@index([skillId])
}

model TemplateAttribute {
  id          String                @id @default(cuid())
  templateId  String
  template    Template              @relation(fields: [templateId], references: [id], onDelete: Cascade)
  key         String
  name        String
  modifier    String?
  order       Int                   @default(0)
  sheetValues CharacterSheetValue[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([templateId])
}

// ── Template Skills ──

model TemplateSkill {
  id                 String                           @id @default(cuid())
  templateId         String
  template           Template                         @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name               String
  description        String?
  formula            String?
  order              Int                              @default(0)
  skillValues        CharacterSheetSkillValue[]
  skillProfileValues CharacterSheetSkillProfileValue[]
  createdAt          DateTime                         @default(now())
  updatedAt          DateTime                         @updatedAt

  @@index([templateId])
}

// ── Character Sheet Skill Values ──

model CharacterSheetSkillValue {
  id              String         @id @default(cuid())
  sheetId         String
  sheet           CharacterSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  skillId         String
  skill           TemplateSkill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
  value           String         @default("")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([sheetId, skillId])
  @@index([sheetId])
  @@index([skillId])
}

// ── Character Sheets ──

model CharacterSheet {
  id                 String                           @id @default(cuid())
  characterName      String
  playerName         String?
  level              Int?                             @default(1)
  hpActual           Int?                             @default(0)
  hpMax              Int?                             @default(0)
  hpNotes            String?                          @default("")
  adventureId        String?
  adventure          Adventure?                       @relation(fields: [adventureId], references: [id], onDelete: SetNull)
  templateId         String
  template           Template                         @relation(fields: [templateId], references: [id], onDelete: Cascade)
  ownerId            String
  owner              User                             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  values             CharacterSheetValue[]
  fieldValues        CharacterSheetFieldValue[]
  skillValues        CharacterSheetSkillValue[]
  skillProfileValues             CharacterSheetSkillProfileValue[]
  runtimeModifierComponentValues CharacterSheetRuntimeModifierComponentValue[]
  acValues                       CharacterSheetArmorClassValue[]
  abilities          CharacterAbility[]
  inventoryItems     CharacterInventoryItem[]
  story              CharacterStory?
  createdAt                      DateTime                         @default(now())
  updatedAt             DateTime                         @updatedAt

  @@index([adventureId])
  @@index([ownerId])
  @@index([templateId])
}

model CharacterSheetValue {
  id          String         @id @default(cuid())
  sheetId     String
  sheet       CharacterSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  attributeId String
  attribute   TemplateAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value       String         @default("")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([sheetId, attributeId])
  @@index([sheetId])
}

// ── Legacy Custom Fields (to be removed by migration) ──

// ── Template Custom Fields ──

model TemplateField {
  id         String                     @id @default(cuid())
  templateId String
  template   Template                   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  key        String
  label      String
  order      Int                        @default(0)
  values     CharacterSheetFieldValue[]
  createdAt  DateTime                   @default(now())
  updatedAt  DateTime                   @updatedAt

  @@index([templateId])
}

// ── Character Sheet Field Values ──

model CharacterSheetFieldValue {
  id              String         @id @default(cuid())
  sheetId         String
  sheet           CharacterSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  templateFieldId String
  templateField   TemplateField  @relation(fields: [templateFieldId], references: [id], onDelete: Cascade)
  value           String         @default("")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([sheetId, templateFieldId])
  @@index([sheetId])
  @@index([templateFieldId])
}

// ── Runtime Modifiers ──

model TemplateRuntimeModifier {
  id          String                     @id @default(cuid())
  templateId  String
  template    Template                   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  key         String
  name        String
  description String?
  order       Int                        @default(0)
  components  RuntimeModifierComponent[]
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  @@index([templateId])
}

model RuntimeModifierComponent {
  id           String                                      @id @default(cuid())
  modifierId   String
  modifier     TemplateRuntimeModifier                      @relation(fields: [modifierId], references: [id], onDelete: Cascade)
  name         String
  defaultValue String?
  locked       Boolean                                      @default(false)
  formula      String?
  order        Int                                          @default(0)
  sheetValues  CharacterSheetRuntimeModifierComponentValue[]
  createdAt    DateTime                                     @default(now())
  updatedAt    DateTime                                     @updatedAt

  @@index([modifierId])
}

// ── Character Sheet Runtime Modifier Component Values ──

model CharacterSheetRuntimeModifierComponentValue {
  id          String                  @id @default(cuid())
  sheetId     String
  sheet       CharacterSheet           @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  componentId String
  component   RuntimeModifierComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  value       String                  @default("")
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@unique([sheetId, componentId])
  @@index([sheetId])
  @@index([componentId])
}

// ── Armor Class (AC) System ──

model TemplateArmorClass {
  id         String                @id @default(cuid())
  templateId String                @unique
  template   Template              @relation(fields: [templateId], references: [id], onDelete: Cascade)
  enabled    Boolean               @default(false)
  formula    String?
  fields     ArmorClassField[]
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
}

model ArmorClassField {
  id                String                             @id @default(cuid())
  armorClassId      String
  armorClass        TemplateArmorClass                 @relation(fields: [armorClassId], references: [id], onDelete: Cascade)
  name              String
  key               String
  defaultValue      String                             @default("0")
  editableByPlayer  Boolean                            @default(false)
  description       String?
  order             Int                                @default(0)
  sheetValues       CharacterSheetArmorClassValue[]
  createdAt         DateTime                           @default(now())
  updatedAt         DateTime                           @updatedAt

  @@unique([armorClassId, key])
  @@index([armorClassId])
}

model CharacterSheetArmorClassValue {
  id          String              @id @default(cuid())
  sheetId     String
  sheet       CharacterSheet      @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  fieldId     String
  field       ArmorClassField     @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  value       String              @default("0")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([sheetId, fieldId])
  @@index([sheetId])
  @@index([fieldId])
}

// ── Character Abilities (Player-only) ──

model CharacterAbility {
  id          String         @id @default(cuid())
  sheetId     String
  sheet       CharacterSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  name        String
  description String?
  manaCost    Int?
  cooldown    String?
  notes       String?
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([sheetId])
}

// ── Character Inventory Items (Player-only) ──

model CharacterInventoryItem {
  id          String         @id @default(cuid())
  sheetId     String
  sheet       CharacterSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  name        String
  weight      Float?
  cost        String?
  description String?
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([sheetId])
}

// ── Character Story (Player-only, one-to-one) ──

model CharacterStory {
  id          String         @id @default(cuid())
  sheetId     String         @unique
  sheet       CharacterSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  appearance  String?        @default("")
  backstory   String?        @default("")
  personality String?        @default("")
  goals       String?        @default("")
  notes       String?        @default("")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}